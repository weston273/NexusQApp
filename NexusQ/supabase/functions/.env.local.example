# Required server-side env for local `supabase functions serve`
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Workflow proxy targets
WORKFLOW_A_URL="https://your-n8n-host/webhook/lead-webhook"
WORKFLOW_D_URL="https://your-n8n-host/webhook/pipeline-update"
WORKFLOW_E_STATUS_URL="https://your-n8n-host/webhook/health-ping"

# Optional shared webhook secrets
# NEXUSQ_WORKFLOW_A_SECRET="your-workflow-a-shared-secret"
# NEXUSQ_PIPELINE_SECRET="your-workflow-d-shared-secret"

# Optional operator alert delivery
# TWILIO_ACCOUNT_SID="your-twilio-account-sid"
# TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# TWILIO_FROM_NUMBER="+15551234567"
# WEB_PUSH_VAPID_PUBLIC_KEY="your-base64url-vapid-public-key"
# WEB_PUSH_VAPID_PRIVATE_KEY="your-base64url-vapid-private-key"
# WEB_PUSH_VAPID_SUBJECT="mailto:alerts@example.com"
