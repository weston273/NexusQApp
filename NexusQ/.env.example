# Replace these placeholders with your real Supabase project values in .env.local.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Optional. If provided, must be an absolute http(s) URL.
# If omitted, frontend falls back to window.location.origin + /auth/callback.
VITE_AUTH_REDIRECT_URL="http://localhost:3000/auth/callback"

# Optional. If provided, must be an absolute http(s) URL.
# If omitted, frontend falls back to window.location.origin + /reset-password.
VITE_PASSWORD_RESET_REDIRECT_URL="http://localhost:3000/reset-password"

# Frontend now calls Supabase Edge Function proxies:
# - workflow-a-proxy
# - workflow-d-proxy
# - workflow-e-proxy
# Do NOT keep webhook secrets in browser env vars.
# Invalid or missing frontend env values now fail fast at startup.

# Optional local-development fallback for lead intake only.
# Production should use the Supabase workflow-a-proxy path.
# VITE_WORKFLOW_A_DEV_FALLBACK_URL="https://n8n-k7j4.onrender.com/webhook/lead-webhook"

# Health monitoring uses the Workflow E health-ping webhook URL as the live reachability probe.
VITE_WORKFLOW_E_HEALTH_URL="https://n8n-k7j4.onrender.com/webhook/health-ping"

# Optional browser-side fallback probe URL if Workflow E is hosted elsewhere.
# VITE_WORKFLOW_E_HEALTH_FALLBACK_URL="https://backup-host/webhook/health-ping"

# Required Supabase Edge Function secrets (set in Supabase project):
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# WORKFLOW_A_URL
# WORKFLOW_D_URL
# WORKFLOW_E_STATUS_URL

# Optional Supabase Edge Function secrets:
# WORKFLOW_A_FALLBACK_URL
# WORKFLOW_D_FALLBACK_URL
# WORKFLOW_E_STATUS_FALLBACK_URL
# NEXUSQ_WORKFLOW_A_SECRET
# NEXUSQ_PIPELINE_SECRET
