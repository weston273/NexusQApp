VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Optional. If omitted, frontend falls back to window.location.origin + /auth/callback.
VITE_AUTH_REDIRECT_URL="http://localhost:5173/auth/callback"

# Optional. If omitted, frontend falls back to window.location.origin + /reset-password.
VITE_PASSWORD_RESET_REDIRECT_URL="http://localhost:5173/reset-password"

# Workflow A intake endpoint.
VITE_WORKFLOW_A_URL="https://your-n8n-host/webhook/lead-webhook"

# Optional fallback endpoint used only if primary fails.
# VITE_WORKFLOW_A_FALLBACK_URL="https://your-secondary-host/webhook/lead-webhook"

# Optional temporary browser-side header for Workflow A.
# Avoid in production if this is a true shared secret.
# VITE_WORKFLOW_A_SECRET="replace-me"

# Workflow D pipeline update endpoint.
VITE_WORKFLOW_D_URL="https://your-n8n-host/webhook/pipeline-update"

# Optional fallback endpoint used only if primary fails.
# VITE_WORKFLOW_D_FALLBACK_URL="https://your-secondary-host/webhook/pipeline-update"

# Optional if Workflow D validates x-nexusq-secret.
# VITE_WORKFLOW_D_SECRET="replace-me"

# Workflow E health status endpoint.
VITE_WORKFLOW_E_STATUS_URL="https://your-n8n-host/webhook/health-status"

# Optional health endpoint fallback.
# VITE_WORKFLOW_E_STATUS_FALLBACK_URL="https://your-secondary-host/webhook/health-status"

# Edge Functions run server-side and require secrets set in Supabase (not in frontend env):
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
