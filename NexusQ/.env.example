VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Optional. If omitted, frontend falls back to window.location.origin + /auth/callback.
VITE_AUTH_REDIRECT_URL="http://localhost:5173/auth/callback"

# Optional. If omitted, frontend falls back to window.location.origin + /reset-password.
VITE_PASSWORD_RESET_REDIRECT_URL="http://localhost:5173/reset-password"

# Frontend now calls Supabase Edge Function proxies:
# - workflow-a-proxy
# - workflow-d-proxy
# - workflow-e-proxy
# Do NOT keep webhook secrets in browser env vars.

# Required Supabase Edge Function secrets (set in Supabase project):
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# WORKFLOW_A_URL
# WORKFLOW_D_URL
# WORKFLOW_E_STATUS_URL

# Optional Supabase Edge Function secrets:
# WORKFLOW_A_FALLBACK_URL
# WORKFLOW_D_FALLBACK_URL
# WORKFLOW_E_STATUS_FALLBACK_URL
# NEXUSQ_WORKFLOW_A_SECRET
# NEXUSQ_PIPELINE_SECRET
