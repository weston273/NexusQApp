    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\n\nconst full_name =\n  body.full_name ||\n  body.name ||\n  `${body.first_name || \"\"} ${body.last_name || \"\"}`.trim();\n\nconst client_id = typeof body.client_id === 'string' ? body.client_id.trim() : '';\nconst client_key = typeof body.client_key === 'string' ? body.client_key.trim().toLowerCase() : '';\nconst phone = body.phone || body.msisdn || body.mobile || \"\";\nconst email = body.email || \"\";\n\nif (!client_id && !client_key) {\n  return [{\n    json: {\n      _error: true,\n      status: 422,\n      message: \"client_id or client_key is required.\"\n    }\n  }];\n}\n\nif (!phone && !email) {\n  return [{\n    json: {\n      _error: true,\n      status: 422,\n      message: \"Missing contact info. Provide phone or email.\"\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    source: body.source || \"webhook\",\n    client_id: client_id || null,\n    client_key: client_key || null,\n\n    full_name,\n    name: full_name,\n\n    first_name: body.first_name || (full_name.split(\" \")[0] || \"\"),\n    last_name: body.last_name || (full_name.split(\" \" ).slice(1).join(\" \" ) || \"\"),\n\n    phone,\n    email,\n\n    message: body.message || body.note || \"\",\n    service: body.service || \"\",\n    urgency: body.urgency || \"\",\n    address: body.address || \"\",\n\n    campaign: body.campaign || \"\",\n    adset: body.adset || \"\",\n    ad: body.ad || \"\",\n    form_id: body.form_id || \"\",\n    page_id: body.page_id || \"\",\n    external_lead_id: body.external_lead_id || body.lead_id || body.id || \"\",\n\n    occurred_at: new Date().toISOString(),\n    raw: body\n  }\n}];"
      },
