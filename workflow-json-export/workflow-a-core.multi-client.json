    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(item => item.json).filter(Boolean);\nconst lead = $node['Normalize + Require client_key'].json;\nconst requestedId = typeof lead.client_id === 'string' && lead.client_id.trim() ? lead.client_id.trim() : null;\nconst requestedKey = typeof lead.client_key === 'string' && lead.client_key.trim() ? lead.client_key.trim().toLowerCase() : null;\n\nif (!rows.length) {\n  return [{ json: { _error: true, status: 404, message: 'No active client matched the provided tenant reference.' } }];\n}\n\nif (rows.length > 1) {\n  return [{ json: { _error: true, status: 409, message: 'Client lookup was ambiguous. Refine the tenant reference.' } }];\n}\n\nconst client = rows[0];\nif (!client?.id) {\n  return [{ json: { _error: true, status: 404, message: 'Resolved client is missing an id.' } }];\n}\n\nconst resolvedId = String(client.id).trim();\nconst resolvedKey = typeof client.client_key === 'string' && client.client_key.trim() ? client.client_key.trim().toLowerCase() : null;\n\nif (requestedId && resolvedId !== requestedId) {\n  return [{ json: { _error: true, status: 409, message: 'client_id did not match the resolved workspace.' } }];\n}\n\nif (requestedKey && !resolvedKey) {\n  return [{ json: { _error: true, status: 500, message: 'Resolved client is missing client_key.' } }];\n}\n\nif (requestedKey && resolvedKey !== requestedKey) {\n  return [{ json: { _error: true, status: 409, message: 'client_key did not match the resolved workspace.' } }];\n}\n\nreturn [{\n  json: {\n    client_id: resolvedId,\n    client_key: resolvedKey,\n    client_phone: client.phone ?? null,\n    client_name: client.name ?? null,\n    client_timezone: client.timezone ?? 'UTC',\n  }\n}];"
      },
