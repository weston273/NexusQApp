    {
      "parameters": {
        "jsCode": "const lead = $node[\"Normalize + Require client_key\"].json; \nconst client_id = $node[\"Set client_id\"].json.client_id;\n\nconst since = new Date(Date.now() - 10 * 60 * 1000).toISOString();\n\nconst clauses = [];\nif (lead.phone) clauses.push(`phone.eq.${encodeURIComponent(lead.phone)}`);\nif (lead.email) clauses.push(`email.eq.${encodeURIComponent(lead.email)}`);\n\nif (clauses.length === 0) {\n  return [{\n    json: {\n      _error: true,\n      status: 422,\n      message: \"No phone/email available for dedupe.\"\n    }\n  }];\n}\n\nconst url =\n  `https://peenmmujciouzulfoykq.supabase.co/rest/v1/leads` +\n  `?client_id=eq.${encodeURIComponent(client_id)}` +\n  `&created_at=gte.${encodeURIComponent(since)}` +\n  `&or=(${clauses.join(\",\")})` +\n  `&select=id` +\n  `&limit=1`;\n\nreturn [{ json: { url, client_id, since } }];\n"
      },
