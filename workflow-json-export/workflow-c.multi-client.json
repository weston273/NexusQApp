    {
      "parameters": {
        "jsCode": "const b = $json.body ?? $json;\n// Twilio typically sends form-encoded fields: From, To, Body\nconst fromRaw = (b.From ?? b.from ?? '').toString();\nconst toRaw   = (b.To   ?? b.to   ?? '').toString();\nconst bodyTxt = (b.Body ?? b.body ?? b.message ?? '').toString();\n\n// basic normalization (remove spaces)\nconst from = fromRaw.replace(/\\s+/g,'');\nconst to   = toRaw.replace(/\\s+/g,'');\n\nreturn [{\n  from, to,\n  message: bodyTxt,\n  raw: b,\n}];"
      },
