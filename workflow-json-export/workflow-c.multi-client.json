    {
      "parameters": {
        "jsCode": "const lead = $json;\nconst first = (lead.name || '').split(' ')[0] || 'there';\n\nconst templates = {\n  day1: `Hi ${first} - just checking in. Would you like a quick quote or to book an inspection today? Reply YES and we'll schedule you.`,\n  day3: `Hi ${first} - following up. If you still need help, reply YES and we'll get you booked in (takes 1 minute).`,\n  day7: `Hi ${first} - last check-in from my side. Reply YES if you want us to help, or NO if you're sorted and I'll close this.`,\n};\n\nconst followup_body = templates[lead.bucket] || templates.day1;\n\nreturn [{\n  ...lead,\n  followup_body,\n}];"
      },
