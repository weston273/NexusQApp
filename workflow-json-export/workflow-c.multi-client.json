    {
      "parameters": {
        "jsCode": "const leads = $input.all().map(i => i.json);\nconst { day1, day3, day7 } = $node['Compute Follow-up Thresholds'].json;\n\nfunction dueBucket(last) {\n  if (!last) return null;           \n  const t = new Date(last).toISOString();\n  if (t <= day7) return 'day7';\n  if (t <= day3) return 'day3';\n  if (t <= day1) return 'day1';\n  return null;\n}\n\nreturn leads\n  .map(l => ({ ...l, bucket: dueBucket(l.last_contacted_at) }))\n  .filter(l => l.bucket && l.phone);"
      },
