        "jsCode": "// Quiet hours rule per client timezone.\n// Block 20:00 - 07:00 local time.\nconst startQuiet = 20;\nconst endQuiet = 7;\nconst tz = $json.client_timezone || 'UTC';\n\nlet localHour;\ntry {\n  localHour = Number(new Intl.DateTimeFormat('en-GB', { hour: 'numeric', hour12: false, timeZone: tz }).format(new Date()));\n} catch {\n  localHour = new Date().getUTCHours();\n}\n\nif (!Number.isFinite(localHour)) {\n  localHour = new Date().getUTCHours();\n}\n\nconst inQuiet = (localHour >= startQuiet) || (localHour < endQuiet);\n\nreturn [{\n  ...$json,\n  client_timezone: tz,\n  localHour,\n  inQuiet,\n  okToSend: !inQuiet,\n}];"
      },
