      "parameters": {
        "jsCode": "const matches = Array.isArray($json) ? $json : [];\nconst tw = $node['Extract Twilio Fields'].json;\n\nif (matches.length !== 1) {\n  return [{\n    _unknownLead: true,\n    _ambiguousLead: matches.length > 1,\n    reason: matches.length > 1 ? 'Ambiguous lead match for inbound reply.' : 'No tenant-safe lead match for inbound reply.',\n    ...tw,\n  }];\n}\n\nconst lead = matches[0];\n\nreturn [{\n  client_id: lead.client_id,\n  lead_id: lead.id,\n  status: lead.status,\n  phone: lead.phone,\n  client_phone: lead?.clients?.phone ?? tw.to,\n  client_timezone: lead?.clients?.timezone ?? 'UTC',\n  message: tw.message,\n  from: tw.from,\n  to: tw.to,\n  raw: tw.raw,\n}];"
      },
