      "parameters": {
        "jsCode": "const arr = Array.isArray($json) ? $json : [];\nconst lead = arr[0];\nconst prev = $node['Compute Quiet Hours'].json;\n\nif (!lead) return [{ _missingLead:true, ...prev }];\n\nreturn [{\n  ...prev,\n  status: lead.status,\n  name: lead.name,\n  phone: lead.phone,\n  client_id: lead.client_id,\n  client_phone: lead?.clients?.phone ?? prev.client_phone ?? null,\n  client_timezone: lead?.clients?.timezone ?? prev.client_timezone ?? 'UTC',\n  id: lead.id,\n}];"
      },
