      "parameters": {
        "jsCode": "function safeItems(nodeName) {\n  try {\n    return $items(nodeName, 0, 0) || [];\n  } catch {\n    return [];\n  }\n}\n\nconst leads = safeItems('Get leads (today)');\nconst events = safeItems('Get lead_events (today)1');\nconst pipeline = safeItems('Get pipeline (today)1');\nconst base = $node['Compute Date Range1'].json;\nconst client_id = base?.client_id ?? null;\nconst today = base?.date || new Date().toISOString().slice(0, 10);\n\nif (!client_id) {\n  throw new Error('client_id is required for daily KPI generation');\n}\n\nconst eventRows = events.map(i => i.json || {});\nconst pipelineRows = pipeline.map(i => i.json || {});\n\nconst countEvent = (name) =>\n  eventRows.filter(e => e.event_type === name).length;\n\nconst hasStage = (stage) =>\n  pipelineRows.filter(p => p.stage === stage).length;\n\nreturn [{\n  client_id,\n  date: today,\n  leads_count: leads.length,\n  responses_sent: countEvent(\"first_response_sent\"),\n  booked_calls: countEvent(\"call_booked\"),\n  quotes_sent: hasStage(\"quoted\"),\n  wins: hasStage(\"won\"),\n  losses: hasStage(\"lost\"),\n}];"
      },
