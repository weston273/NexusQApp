    {
      "parameters": {
        "jsCode": "// Output format expected by frontend Health.tsx:\n// { ok, allOperational, services[], logs[], generated_at }\nfunction safeItems(nodeName) {\n  try {\n    const items = $items(nodeName);\n    return items?.[0]?.json ?? [];\n  } catch (e) {\n    return [];\n  }\n}\nconst healthRaw = safeItems('Get automation_health (recent)');\nconst kpiRaw = safeItems('Get daily_kpis (latest)');\n\nconst healthRows = Array.isArray(healthRaw) ? healthRaw : (Array.isArray(healthRaw.data) ? healthRaw.data : (healthRaw ? [healthRaw] : []));\n\nconst latestByWorkflow = {};\nfor (const r of healthRows) {\n  const name = r.workflow_name || 'unknown';\n  const prev = latestByWorkflow[name];\n  if (!prev) {\n    latestByWorkflow[name] = r;\n    continue;\n  }\n  const a = prev.last_run_at ? new Date(prev.last_run_at).getTime() : 0;\n  const b = r.last_run_at ? new Date(r.last_run_at).getTime() : 0;\n  if (b >= a) latestByWorkflow[name] = r;\n}\n\nconst now = Date.now();\nconst STALE_MINUTES = 90;\n\nfunction mapStatus(row, minutesSince) {\n  const s = String(row?.status || '').toLowerCase();\n  if (minutesSince == null) return 'unknown';\n  if (minutesSince > STALE_MINUTES) return 'stale';\n  if (s === 'error' || s === 'failed' || s === 'degraded') return 'degraded';\n  if (s === 'ok' || s === 'success' || s === 'optimal') return 'optimal';\n  if (s === 'warning' || s === 'warn' || s === 'stale' || s === 'delayed') return 'stale';\n  return 'unknown';\n}\n\nfunction deriveError(row, status, name) {\n  const explicit = [row?.error_message, row?.error, row?.message].find(value => typeof value === 'string' && value.trim());\n  if (explicit) return String(explicit).trim();\n  if (status === 'degraded') return `${name} reported a degraded status without an explicit error message.`;\n  if (status === 'stale') return `${name} heartbeat is stale.`;\n  return null;\n}\n\nconst services = Object.entries(latestByWorkflow)\n  .map(([name, r]) => {\n    const t = r.last_run_at ? new Date(r.last_run_at).getTime() : 0;\n    const minutes_since = t ? Math.round((now - t) / 60000) : null;\n    const status = mapStatus(r, minutes_since);\n\n    return {\n      name,\n      status,\n      last_run_at: r.last_run_at || null,\n      minutes_since,\n      error: deriveError(r, status, name),\n    };\n  })\n  .sort((a, b) => a.name.localeCompare(b.name));\n\nconst allOperational = services.length ? services.every(s => s.status === 'optimal') : false;\n\nconst logs = services\n  .map(s => ({\n    time: s.last_run_at,\n    event:\n      s.error ? s.error :\n      s.status === 'optimal' ? 'Heartbeat OK' :\n      s.status === 'stale' ? 'Heartbeat stale' :\n      s.status === 'degraded' ? 'Workflow error' :\n      'Unknown status',\n    source: s.name,\n    status:\n      s.status === 'optimal' ? 'success' :\n      (s.status === 'stale' || s.status === 'degraded') ? 'warning' :\n      'info',\n  }))\n  .sort((a, b) => (b.time ? new Date(b.time).getTime() : 0) - (a.time ? new Date(a.time).getTime() : 0))\n  .slice(0, 30);\n\nreturn [{\n  ok: true,\n  allOperational,\n  services,\n  logs,\n  generated_at: new Date().toISOString(),\n  latest_kpi: (Array.isArray(kpiRaw) && kpiRaw.length) ? kpiRaw[0] : null,\n}];"
      },
