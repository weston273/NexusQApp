{
  "name": "E",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\n\nconst client_id =\n  body.client_id ||\n  body.clientId ||\n  body.client ||\n  body.workspace_client_id ||\n  null;\n\nconst workflow_name = String(\n  body.workflow_name || body.workflowName || body.workflow || \"\"\n).trim();\n\nconst rawStatus = String(body.status || \"ok\").toLowerCase().trim();\n\nlet status = \"unknown\";\nif ([\"ok\", \"optimal\", \"healthy\", \"success\"].includes(rawStatus)) status = \"optimal\";\nelse if ([\"stale\", \"delayed\", \"warning\", \"warn\"].includes(rawStatus)) status = \"stale\";\nelse if ([\"degraded\", \"error\", \"fail\", \"failed\"].includes(rawStatus)) status = \"degraded\";\n\nconst explicitError = [body.error_message, body.error, body.message]\n  .find(value => typeof value === 'string' && value.trim()) ?? null;\n\nlet error_message = explicitError ? String(explicitError).trim().slice(0, 500) : null;\n\nif (!error_message && status === 'degraded') {\n  error_message = `${workflow_name || 'Workflow'} reported a degraded status without an explicit error message.`.slice(0, 500);\n} else if (!error_message && status === 'stale') {\n  error_message = `${workflow_name || 'Workflow'} heartbeat is stale.`.slice(0, 500);\n} else if (!error_message && status === 'unknown' && rawStatus) {\n  error_message = `${workflow_name || 'Workflow'} returned an unrecognized status: ${rawStatus}`.slice(0, 500);\n}\n\nlet last_run_at = new Date().toISOString();\nif (body.last_run_at) {\n  const d = new Date(body.last_run_at);\n  if (!Number.isNaN(d.getTime())) {\n    last_run_at = d.toISOString();\n  }\n}\n\nif (!client_id) {\n  return [{\n    _error: true,\n    message: \"client_id is required\",\n    received: body,\n  }];\n}\n\nif (!workflow_name) {\n  return [{\n    _error: true,\n    message: \"workflow_name is required\",\n    received: body,\n  }];\n}\n\nreturn [{\n  _error: false,\n  client_id,\n  workflow_name,\n  last_run_at,\n  status,\n  error_message,\n}];"
      },
