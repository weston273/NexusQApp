    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\n\n// Required\nif (!body.lead_id) return [{ _error: true, status: 400, message: 'Missing lead_id' }];\n\n// Optional: allow client_id to be passed in, otherwise we will resolve it from the lead record\nconst client_id = body.client_id ?? null;\n\nconst rawStatus = String(body.status || body.stage || '').toLowerCase().trim();\n\n// Map incoming status -> standard stage + event_type\nlet stage = 'new';\nlet event_type = 'quote_sent';\nif (rawStatus.includes('book')) { stage='booked'; event_type='booking_created'; }\nelse if (rawStatus.includes('quote')) { stage='quoted'; event_type='quote_sent'; }\nelse if (rawStatus.includes('qual') || rawStatus.includes('inspect')) { stage='qualifying'; event_type='status_changed'; }\nelse if (rawStatus.includes('won')) { stage='booked'; event_type='deal_won'; }\nelse if (rawStatus.includes('lost')) { stage='new'; event_type='deal_lost'; }\n\nconst probability = stage === 'new' ? 10 : stage === 'qualifying' ? 35 : stage === 'quoted' ? 60 : 100;\n\nreturn [{\n  client_id,\n  lead_id: body.lead_id,\n  stage,\n  value: body.value ?? null,\n  probability,\n  event_type,\n  raw: body\n}];\n"
      },
