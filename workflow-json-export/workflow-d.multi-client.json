        "jsCode": "const requestedClientId = $node['Validate + Map Status'].json.client_id ?? null;\nconst rows = $node['Get Client'].json;\nconst lead = Array.isArray(rows) ? rows[0] : null;\n\nif (!lead?.client_id) {\n  return [{ _error: true, status: 404, message: 'Lead not found / missing client_id' }];\n}\n\nif (requestedClientId && requestedClientId !== lead.client_id) {\n  return [{ _error: true, status: 400, message: 'client_id does not match the lead tenant context' }];\n}\n\nreturn [{ client_id: lead.client_id }];"
