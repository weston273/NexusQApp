    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst headers = $json.headers ?? {};\n\nconst expectedSecret = $json.expected_secret;\n\nconst secret =\n  headers[\"x-nexusq-secret\"] ||\n  headers[\"X-NexusQ-Secret\"];\n\nif (secret !== expectedSecret) {\n  return [{\n    _error: true,\n    status: 401,\n    message: \"Unauthorized\",\n  }];\n}\n\nif (!body.lead_id) {\n  return [{\n    _error: true,\n    status: 400,\n    message: \"Missing lead_id\",\n  }];\n}\n\nreturn [{\n  _error: false,\n  ...body,\n}];\n"
