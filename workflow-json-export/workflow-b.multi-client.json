    {
      "parameters": {
        "jsCode": "let phone = $('Get Lead').item.json.phone || \"\";\n\n// Remove spaces, dashes, brackets\nphone = phone.replace(/[\\s()-]/g, \"\");\n\n// Zimbabwe local format: 0771840862 → +263771840862\nif (phone.startsWith(\"0\")) {\n  phone = \"+263\" + phone.slice(1);\n}\n\n// 263771840862 → +263771840862\nif (phone.startsWith(\"263\")) {\n  phone = \"+\" + phone;\n}\n\n// Ensure it starts with +\nif (!phone.startsWith(\"+\")) {\n  return [{ json: { _skip: true, reason: \"Phone missing country code\" } }];\n}\n\n// Validate E.164 format (10–15 digits after +)\nconst isValid = /^\\+\\d{10,15}$/.test(phone);\n\nif (!isValid) {\n  return [{ json: { _skip: true, reason: \"Invalid phone format\" } }];\n}\n\nreturn [{ json: { ...$('Get Lead').item.json, phone } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        416
      ],
      "id": "02a23fe2-267d-40f6-93d6-4dd226230616",
      "name": "normalise phone"
    },
