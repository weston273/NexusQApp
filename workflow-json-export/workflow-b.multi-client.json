      "parameters": {
        "jsCode": "const lead = Array.isArray($json) ? $json[0] : null;\nconst event = $node['Split Events'].json;\nconst clientPhone = lead?.clients?.phone ?? null;\n\nif (!lead?.id || !lead?.client_id) return [{ _skip:true, reason:'Lead missing tenant context' }];\nif (event?.client_id && lead.client_id !== event.client_id) return [{ _skip:true, reason:'Lead client_id does not match event client_id' }];\nif (!lead?.phone) return [{ _skip:true, reason:'No phone' }];\nif (!clientPhone) return [{ _skip:true, reason:'Client sender phone is not configured' }];\n\nreturn [{\n  lead_id: lead.id,\n  client_id: lead.client_id,\n  to: lead.phone,\n  from: clientPhone,\n  client_timezone: lead?.clients?.timezone ?? 'UTC',\n  name: lead.name || 'there'\n}];"
      },
