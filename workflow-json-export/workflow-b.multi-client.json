        "jsCode": "// Split Events (robust)\n// Works whether the previous node returns:\n// - 0 items\n// - 1 empty item {}\n// - many items (normal case)\n\nconst items = $input.all();\n\n// If previous node returned nothing at all\nif (!items || items.length === 0) {\n  return [{ json: { _no_events: true } }];\n}\n\n// If previous node forced an empty item (like [{}])\nif (items.length === 1) {\n  const j = items[0].json || {};\n  if (Object.keys(j).length === 0) {\n    return [{ json: { _no_events: true } }];\n  }\n}\n\n// Normal case: output each event as its own item\nreturn items.map(i => ({ json: i.json }));\n"
      },
